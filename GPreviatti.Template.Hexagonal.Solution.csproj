<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>GPreviatti.Template.Hexagonal.Solution</PackageId>
    <Title>Hexagonal architecture solution template</Title>
    <Authors>Giovanni Brunno Previatti</Authors>
    <Description>Solution following Hexagonal architecture and best practices.</Description>
    <PackageTags>template;hexagonal-architecture;clean-architecture;ddd;net8</PackageTags>
    <TargetFramework>net10.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <PackageProjectUrl>https://github.com/gpreviatti/hexagonal-solution-template</PackageProjectUrl>
    <PackageReadmeFile>Readme.md</PackageReadmeFile>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>git://github.com/gpreviatti/hexagonal-solution-template</RepositoryUrl>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReleaseNotes>
      ## New Features
      - Added continuous support for Grafana and Pyroscope integration for continuous profiling
      - Added Pyroscope profiling configuration in Docker Compose and launch settings
      - Added OpenTelemetry metrics collection with meter configuration
      - Added DomainException class for improved exception handling
      - Enhanced activity tracing with default tags support
      - Added service namespace configuration to OpenTelemetry
      - Added period tracking for order creation with new Order Details entity field
      - Added Contracts template providing a contracts-only solution structure
      
      ## Improvements
      - Enhanced GitHub Actions workflows for improved validation and package publishing
      - Updated web app host address configuration and enhanced logging settings
      - Improved activity status handling for better distributed tracing support
      - Refactored to use nameof() for activity tags instead of string literals
      - Simplified GetPeriodSinceWasCreated return type and improved data access patterns
      - Added launch and tasks configuration for streamlined development experience
      - Removed unused environment variables from launch settings
      
      ## Code Quality
      - Applied consistent styling and removed emojis from template headers
      - Cleaned up unused namespace imports across the solution
      - Improved tracing activity name consistency in request handlers
      - Enhanced metrics collection with application name prefixes
      
      ## Technical Details
      - OpenTelemetry: Full meter configuration with metrics collection across use cases and consumers
      - Pyroscope: Continuous profiling with Grafana datasource configuration
      - Tracing: Enhanced activity handling with default tags and status tracking
    </PackageReleaseNotes>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="templates\**\*" Exclude="templates\**\bin\**;templates\**\obj\**" />
    <Compile Remove="**\*" />
    <None Include="Readme.md" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>