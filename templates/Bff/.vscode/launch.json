{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WebApp [Development]",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build WebApp",
            "program": "${workspaceFolder}/src/WebApp/bin/Debug/net10.0/WebApp.dll",
            "args": [
                    "--urls", "http://localhost:5011"
            ],
            "cwd": "${workspaceFolder}/src/WebApp",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "MockApi [Development]",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build MockApi",
            "program": "${workspaceFolder}/src/MockApi/bin/Debug/net10.0/MockApi.dll",
            "args": [
                "--urls", "http://localhost:5012"
            ],
            "cwd": "${workspaceFolder}/src/MockApi",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}