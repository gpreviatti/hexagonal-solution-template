{
  "stryker-config": {
    "reporters": [
      "progress",
      "html"
    ],
    "project": "Domain.csproj",
    "report-file-name": "mutation-tests-domain-result",
    "thresholds": {
      "high": 90,
      "low": 80,
      "break": 50
    },
    "ignore-methods": [
      "StartActivity",
      "SetTag",
      "SetDefaultTags"
    ],
    "mutate": [
      "!**/*DomainDependencyInjection.cs",
      "!**/*Common/**"
    ]
  }
}