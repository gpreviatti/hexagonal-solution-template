{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WebApp [Development]",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/WebApp/bin/Debug/net10.0/WebApp.dll",
            "cwd": "${workspaceFolder}/src/WebApp",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}