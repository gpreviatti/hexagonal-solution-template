<h1>Orders</h1>

@if (_summary is null)
{
    <p data-testid="loading-summary">Loading summary...</p>
}
else
{
    <ul data-testid="order-summary">
        <li data-testid="total-orders">Total orders: @_summary.TotalOrders</li>
        <li data-testid="total-revenue">Total revenue: @_summary.TotalRevenue @_summary.Currency</li>
    </ul>

    @if (_orders is null)
    {
        <p data-testid="loading-orders">Loading orders...</p>
    }
    else
    {
        <h2>Orders</h2>
        <table data-testid="orders-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Description</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr data-testid="order-row">
                        <td data-testid="order-id-@order.Id">@order.Id</td>
                        <td data-testid="order-customer-@order.Id">@order.Description</td>
                        <td data-testid="order-amount-@order.Id">@order.Total</td>
                        <td>
                            <button class="btn" data-testid="view-items-@order.Id" @onclick="() => ToggleOrderItems(order)">
                                @(IsOrderSelected(order) ? "Hide items" : "View items")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_showOrderItems && _selectedOrder is not null)
        {
            <section data-testid="order-items-section">
                <h2>Items for order @_selectedOrder.Id</h2>

                @if (!HasSelectedOrderItems)
                {
                    <p data-testid="order-items-empty">No items available for this order.</p>
                }
                else
                {
                    <table data-testid="order-items-table">
                        <thead>
                            <tr>
                                <th>Item Id</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _selectedOrderItems!)
                            {
                                <tr data-testid="order-item-row">
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>@item.Description</td>
                                    <td>@item.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        }
    }
}

<hr>
